# =============================================================================
# Discord Hermes Admin Bot — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before running.
#   cp .env.example .env
#
# REQUIRED FIELDS are marked with ⚠️
# OPTIONAL FIELDS have sensible defaults or improve context-awareness
# =============================================================================

# ─── Discord Bot ─────────────────────────────────────────────────────────────
# ⚠️ Your Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=

# ⚠️ Discord Server (Guild) ID — Right-click your server icon → Copy ID
GUILD_ID=

# ⚠️ Comma-separated Discord User IDs allowed to control the bot
#    Right-click a user → Copy ID for each admin
ADMIN_USER_IDS=

# Optional: Restrict bot to specific channel IDs (comma-separated)
# Leave empty to allow commands from any channel + DMs
COMMAND_CHANNEL_IDS=

# ─── LLM Provider (OpenRouter) ───────────────────────────────────────────────
# ⚠️ Your OpenRouter API Key (from https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Model to use for planning (default: claude-sonnet-4-20250514)
# Options: anthropic/claude-3.5-sonnet, nvidia/nemotron-3-ultra, etc.
OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514

# ─── Hermes Context (Pre-Fill from Your Profile) ─────────────────────────────
# These personalize the bot's decisions — exam dates, study habits, etc.
# They flow into every planning request automatically.

# Your username/identifier
HERMES_USER_ID=

# Current module/course code (e.g., ST4003CMD)
HERMES_MODULE=

# Exam date & time in ISO 8601 format (e.g., 2026-07-10T19:00:00)
HERMES_EXAM_DATE=

# Daily study hours
HERMES_STUDY_HOURS=14

# Your timezone
HERMES_TIMEZONE=UTC

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
